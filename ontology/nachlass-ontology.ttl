    rdfs:domain nachlass:NachlassObjekt ;
    rdfs:range nachlass:ProvenienzmerkmalInstanz .

nachlass:hatMerkmaltyp
    a owl:ObjectProperty ;
    rdfs:label "hat Merkmaltyp"@de , "has feature type"@en ;
    rdfs:domain nachlass:ProvenienzmerkmalInstanz ;
    rdfs:range skos:Concept .

# --- 7.5 Orts-Beziehungen ---

nachlass:wirdAufbewahrtIn
    a owl:ObjectProperty ;
    rdfs:label "wird aufbewahrt in"@de , "is held at"@en ;
    rdfs:domain nachlass:NachlassObjekt ;
    rdfs:range nachlass:Aufbewahrungsort ;
