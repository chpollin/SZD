nachlass:hatOrt
    a owl:ObjectProperty ;
    rdfs:label "hat Ort"@de , "has place"@en ;
    rdfs:domain nachlass:BiographischesEreignis ;
    rdfs:range nachlass:Ort .

nachlass:betrifftPerson
    a owl:ObjectProperty ;
    rdfs:label "betrifft Person"@de , "concerns person"@en ;
    rdfs:domain nachlass:BiographischesEreignis ;
    rdfs:range nachlass:Person .

nachlass:hatBeilage
    a owl:ObjectProperty ;
    rdfs:label "hat Beilage"@de , "has enclosure"@en ;
    rdfs:domain nachlass:NachlassObjekt ;
    rdfs:range nachlass:Beilage .

nachlass:hatUmfang
    a owl:ObjectProperty ;
    rdfs:label "hat Umfang"@de , "has extent"@en ;
    rdfs:domain nachlass:NachlassObjekt ;
    rdfs:range nachlass:Umfang .


