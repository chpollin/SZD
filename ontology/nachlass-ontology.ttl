    a owl:ObjectProperty ;
    rdfs:label "hat Provenienz"@de , "has provenance"@en ;
    rdfs:domain nachlass:NachlassObjekt ;
    rdfs:range nachlass:Provenienzereignis .

nachlass:hatVorbesitzer
    a owl:ObjectProperty ;
    rdfs:label "hat Vorbesitzer"@de , "has previous owner"@en ;
