nachlass:hatEntstehungsort
    a owl:ObjectProperty ;
    rdfs:label "hat Entstehungsort"@de , "has place of origin"@en ;
    rdfs:domain nachlass:NachlassObjekt ;
    rdfs:range nachlass:Ort .

nachlass:hatPublikationsort
    a owl:ObjectProperty ;
    rdfs:label "hat Publikationsort"@de , "has publication place"@en ;
    rdfs:domain nachlass:Manifestation ;
    rdfs:range nachlass:Ort .

nachlass:hatVerlag
    a owl:ObjectProperty ;
    rdfs:label "hat Verlag"@de , "has publisher"@en ;
    rdfs:domain nachlass:Manifestation ;
    rdfs:range nachlass:Organisation .

