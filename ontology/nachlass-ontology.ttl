nachlass:hatNachbesitzer
    a owl:ObjectProperty ;
    rdfs:label "hat Nachbesitzer"@de , "has subsequent owner"@en ;
    rdfs:domain nachlass:Provenienzereignis ;
    rdfs:range nachlass:Akteur .

nachlass:hatProvenienzmerkmal
    a owl:ObjectProperty ;
