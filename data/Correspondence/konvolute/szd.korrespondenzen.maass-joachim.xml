        <prefixDef ident="szdg" matchPattern="([(a-z)|(A-Z)]+)" replacementPattern="szdg:$1">
          <p>Namespace für den Glossar in Stefan Zweig digital.</p>
        </prefixDef>
      </listPrefixDef>
    </encodingDesc>
