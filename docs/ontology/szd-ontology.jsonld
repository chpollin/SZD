  {
    "@id": "https://gams.uni-graz.at/o:szd.ontology",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-03-29"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Christopher Pollin, Digital Humanities Craft OG"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "Ontologie zur Beschreibung des digitalen Nachlasses von Stefan Zweig. Modelliert archivalische, bibliographische und biographische Entitäten und deren Beziehungen. Version 1.0.0 formalisiert und erweitert die implizite szd:-Ontologie aus dem GAMS-Repositorium (v0.x)."
      },
      {
        "@language": "en",
        "@value": "Ontology for describing the digital estate of Stefan Zweig. Models archival, bibliographic, and biographical entities and their relationships. Version 1.0.0 formalizes and extends the implicit szd: ontology from the GAMS repository (v0.x)."
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://creativecommons.org/licenses/by/4.0/"
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-03-29"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "de",
        "@value": "Stefan Zweig Digital Nachlass-Ontologie"
      },
      {
        "@language": "en",
        "@value": "Stefan Zweig Digital Estate Ontology"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "de",
        "@value": "Versionierung: Die Vorgängerversion (v0.x) ist implizit in szd-TORDF.xsl definiert und wird im GAMS-Repositorium produktiv genutzt. Diese Version (v1.0.0) formalisiert alle Klassen und Properties, fügt RiC-O/LRM/CRM-Alignments hinzu und definiert die GAMS-Kompatibilitätsschicht (PART 10)."
      },
      {
        "@language": "en",
        "@value": "Versioning: The prior version (v0.x) is implicitly defined in szd-TORDF.xsl and used in production on the GAMS repository. This version (v1.0.0) formalizes all classes and properties, adds RiC-O/LRM/CRM alignments, and defines the GAMS compatibility layer (PART 10)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://chpollin.github.io/SZD/ontology/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@id": "https://stefanzweig.digital"
      }
    ],
    "http://www.w3.org/2002/07/owl#backwardCompatibleWith": [
      {
        "@id": "https://gams.uni-graz.at/o:szd.ontology/0.x"
      }
    ],
    "http://www.w3.org/2002/07/owl#imports": [
      {
        "@id": "https://www.ica.org/standards/RiC/ontology"
      }
    ],
    "http://www.w3.org/2002/07/owl#priorVersion": [
      {
        "@id": "https://gams.uni-graz.at/o:szd.ontology/0.x"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionIRI": [
      {
        "@id": "https://gams.uni-graz.at/o:szd.ontology/1.0.0"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "1.0.0"
      }
    ]
  },
